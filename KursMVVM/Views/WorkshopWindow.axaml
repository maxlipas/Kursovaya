<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
        Width="350" Height="200"
        x:Class="KursMVVM.WorkshopWindow"
        Title="Цех">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition/>
      <RowDefinition/>
      <RowDefinition/>
    </Grid.RowDefinitions>
    <TextBox Grid.Row="0" Margin="10" Watermark="Наименование" Text="{Binding Workshop.Name}" x:Name="NameBox"/>
    <TextBox Grid.Row="1" Margin="10" Watermark="Начальник" Text="{Binding Workshop.Manager}" x:Name="ManagerBox"/>
    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition/>
        <ColumnDefinition/>
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="Сохранить" HorizontalAlignment="Center" Click="Save_Click"/>
      <Button Grid.Column="1" Content="Отменить" HorizontalAlignment="Center" Click="Cancel_Click"/>
    </Grid>
  </Grid>
</Window>

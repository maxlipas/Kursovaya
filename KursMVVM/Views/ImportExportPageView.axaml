<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:KursMVVM.ViewModels"
             x:Class="KursMVVM.ImportExportPageView"
             x:DataType="vm:ImportExportPageViewModel">
  <Design.DataContext>
    <vm:ImportExportPageViewModel/>
  </Design.DataContext>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
      <TextBlock Text="Сущность:" VerticalAlignment="Center" Margin="0 0 10 0"/>
      <ComboBox ItemsSource="{Binding Entities}" SelectedItem="{Binding SelectedEntity}" Width="150"/>
      <Button Content="Импорт" Margin="10 0" Command="{Binding ImportCommand}"/>
      <Button Content="Экспорт" Margin="10 0" Command="{Binding ExportCommand}"/>
    </StackPanel>
    <TextBlock Grid.Row="1" Text="Логи:" Margin="10 5"/>
    <ListBox Grid.Row="2" Margin="10" ItemsSource="{Binding Logs}"/>
  </Grid>
</UserControl>
